<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 160" width="100%" height="100%">
  <!-- Definicja siatki matematycznej w tle (identyczna jak w pierwszej animacji dla spójności bloga) -->
  <defs>
    <pattern id="math-grid" width="16" height="16" patternUnits="userSpaceOnUse">
      <path d="M 16 0 L 0 0 0 16" fill="none" stroke="rgba(203, 213, 225, 0.25)" stroke-width="1"/>
    </pattern>
  </defs>
  
  <!-- Jasnoszare, techniczne tło projektowe (kratka zeszytu) -->
  <rect width="100%" height="100%" fill="#f8fafc" />
  <rect width="100%" height="100%" fill="url(#math-grid)" />
  
  <!-- DELIKATNE OSIE UKŁADU WSPÓŁRZĘDNYCH W TLE -->
  <!-- Oś Y (pionowa) -->
  <line x1="80" y1="15" x2="80" y2="145" stroke="rgba(203, 213, 225, 0.4)" stroke-width="1.5" stroke-dasharray="3 3" />
  <!-- Oś X (pozioma) -->
  <line x1="15" y1="80" x2="145" y2="80" stroke="rgba(203, 213, 225, 0.4)" stroke-width="1.5" stroke-dasharray="3 3" />
  <!-- Strzałki osi -->
  <polygon points="80,10 83,16 77,16" fill="rgba(203, 213, 225, 0.5)" />
  <polygon points="150,80 144,83 144,77" fill="rgba(203, 213, 225, 0.5)" />
  
  <!-- Cienki okrąg pomocniczy (okrąg trygonometryczny) -->
  <circle cx="80" cy="80" r="72" fill="none" stroke="rgba(203, 213, 225, 0.15)" stroke-width="1" stroke-dasharray="2 4" />
  <circle cx="80" cy="80" r="65" fill="none" stroke="rgba(203, 213, 225, 0.4)" stroke-width="1.5" />
  
  <!-- NOWE FIGURY GEOMETRYCZNE (ZMAPOWANE POD TWÓJ SILNIK GSAP) -->
  <!-- Niebieski, przerywany okrąg (kręci się w prawo) -->
  <circle cx="80" cy="80" r="50" class="gsap-rotate-cw" fill="none" stroke="#3b82f6" stroke-width="2" stroke-dasharray="6 8" />
  
  <!-- Złoty romb/diament geometryczny (obraca się w lewo i pulsuje) -->
  <polygon points="80,45 115,80 80,115 45,80" class="gsap-pulse-rotate" fill="none" stroke="#f59e0b" stroke-width="2.5" stroke-linejoin="round" />
  
  <!-- Falująca zielona sinusoida (pływa płynnie góra-dół) -->
  <path d="M 25 90 Q 52.5 50, 80 90 T 135 90" class="gsap-float-y" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" />
  
  <!-- KOLOROWE SYMBOLE (ZMAPOWANE POD TWÓJ SILNIK GSAP) -->
  <!-- Różowy pierwiastek (lewitacja 1) -->
  <text x="35" y="55" class="gsap-bounce-1" font-family="'Arial Rounded MT Bold', 'Arial', sans-serif" font-size="20" font-weight="bold" fill="#ec4899" text-anchor="middle">√</text>
  
  <!-- Fioletowy procent (lewitacja 2) -->
  <text x="125" y="115" class="gsap-bounce-2" font-family="'Arial Rounded MT Bold', 'Arial', sans-serif" font-size="20" font-weight="bold" fill="#8b5cf6" text-anchor="middle">%</text>
</svg>
